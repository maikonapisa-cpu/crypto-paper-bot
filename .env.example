# ============================================================
# CryptoPaperBot — Environment Configuration
# ============================================================
# COPY THIS FILE TO .env AND EDIT AS NEEDED
# DO NOT COMMIT .env TO VERSION CONTROL
# ============================================================

# ---- MODE (CRITICAL — DO NOT CHANGE TO "live") -------------
# Valid values: paper
# "live" mode is not implemented. Setting this to "live" will
# be rejected at startup. A future gated extension is required
# to enable live trading, which will require additional safety
# checks, explicit opt-in, and live credentials.
MODE=paper

# ---- Application -----------------------------------------
NODE_ENV=development
API_PORT=3001
WEB_PORT=3000
LOG_LEVEL=info

# ---- Database --------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cryptopaperbot
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ---- Redis (optional — for stream caching) ---------------
REDIS_URL=redis://localhost:6379
REDIS_ENABLED=false

# ---- Market Data (PUBLIC endpoints only) -----------------
# Supported exchanges: binance-public, bybit-public, okx-public
EXCHANGE_ADAPTER=binance-public

# Public WebSocket endpoint (no auth required)
# This connects to public market data streams only.
EXCHANGE_WS_URL=wss://stream.binance.com:9443/ws

# Public REST endpoint (no auth required)
EXCHANGE_REST_URL=https://api.binance.com

# WebSocket reconnect delay (ms)
WS_RECONNECT_DELAY_MS=3000

# Stale data threshold (ms) — triggers circuit breaker if exceeded
STALE_DATA_THRESHOLD_MS=10000

# ---- Paper Wallet ----------------------------------------
PAPER_WALLET_INITIAL_USDT=10000
PAPER_WALLET_CURRENCY=USDT

# ---- Simulation Assumptions ------------------------------
# These are estimates. Actual exchange behavior may differ.
PAPER_FEE_RATE_MAKER=0.001
PAPER_FEE_RATE_TAKER=0.001
PAPER_SLIPPAGE_BPS=5
# 1 BPS = 0.01% — default 5 BPS = 0.05% slippage assumption

# ---- Strategy Defaults -----------------------------------
STRATEGY_TAKE_PROFIT_PCT=5.0
STRATEGY_STOP_LOSS_PCT=0
# Set STRATEGY_STOP_LOSS_PCT=0 to disable stop-loss
STRATEGY_DEFAULT_PAIR=BTCUSDT

# ---- Risk Limits -----------------------------------------
RISK_MAX_CONCURRENT_POSITIONS=3
RISK_MAX_POSITION_SIZE_PCT=20
# Max % of total portfolio per single position
RISK_MAX_DAILY_LOSS_PCT=10
# Circuit breaker triggers if portfolio drops this % in one day
RISK_COOLDOWN_PERIOD_SEC=60
# Seconds to wait between consecutive signals on same pair

# ---- Analytics -------------------------------------------
ANALYTICS_EQUITY_SNAPSHOT_INTERVAL_SEC=300
# How often to snapshot equity curve (seconds)

# ---- DO NOT ADD LIVE TRADING KEYS HERE ------------------
# EXCHANGE_API_KEY=        <-- DO NOT SET
# EXCHANGE_API_SECRET=     <-- DO NOT SET
# These keys would only be used by a future live trading layer
# that is explicitly gated and not part of this version.
